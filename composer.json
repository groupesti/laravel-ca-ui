{
    "name": "groupesti/laravel-ca-ui",
    "description": "Admin dashboard UI for Laravel CA",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "groupesti/laravel-ca": "^0.1",
        "groupesti/laravel-ca-key": "^0.1",
        "groupesti/laravel-ca-csr": "^0.1",
        "groupesti/laravel-ca-crt": "^0.1",
        "groupesti/laravel-ca-crl": "^0.1",
        "groupesti/laravel-ca-ocsp": "^0.1",
        "illuminate/support": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/view": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CA\\Ui\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CA\\Ui\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CA\\Ui\\UiServiceProvider"
            ]
        }
    }
}
